# Copy these names into Doppler secrets. Do not commit real values.

# For B2.5, use the direct Neon PostgreSQL connection string with sslmode=require.
# Pooled Neon runtime connections can be introduced later with a separate adapter decision.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.example.invalid/DB?sslmode=require"

NEXTAUTH_SECRET="replace-with-at-least-32-random-characters"
AUTH_GITHUB_ID="replace-with-github-oauth-client-id"
AUTH_GITHUB_SECRET="replace-with-github-oauth-client-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
